# ============================================================================
# Hermes Agent — Railway Environment Variables
# ============================================================================
# Configure these variables in the Railway dashboard (Settings > Variables).
# DO NOT commit secrets to this file — it serves only as documentation.
# ============================================================================

# --- REQUIRED ---

# Anthropic API Key (direct access, no OpenRouter needed)
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Discord Bot Token — from Discord Developer Portal
# Get at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# --- OPTIONAL ---

# Default LLM model (Anthropic format)
LLM_MODEL=claude-haiku-4-5

# Comma-separated Discord user IDs allowed to interact with the bot
# Leave empty to allow all users (not recommended in production)
DISCORD_ALLOWED_USERS=

# Default Discord channel ID for cron/scheduled message delivery
DISCORD_HOME_CHANNEL=
DISCORD_HOME_CHANNEL_NAME=

# Require @mention to trigger the bot (default: true)
DISCORD_REQUIRE_MENTION=true

# Auto-create threads for conversations (default: true)
DISCORD_AUTO_THREAD=true

# Show reaction emojis on messages (default: true)
DISCORD_REACTIONS=true

# --- LLM WIKI (agent-maintained knowledge base) ---
#
# The `llm-wiki` skill maintains a compounding, interlinked markdown knowledge
# base. Point it at a path on the persisted Railway volume so it survives
# redeploys. REQUIRES a Railway volume mounted at /opt/data (Dashboard >
# Resources) — without it, /opt/data is ephemeral and the wiki is wiped on every
# deploy. Set explicitly; do not rely on the skill's ~/wiki default, because the
# container user's $HOME is not guaranteed to be the persisted volume.
WIKI_PATH=/opt/data/wiki

# --- DESKTOP APP / REMOTE DASHBOARD ---
#
# Expose the web dashboard so the Hermes Desktop app can connect to this
# Railway-hosted agent (Desktop: Settings > Gateway > Remote gateway). The
# dashboard serves the same REST + WebSocket API the Desktop app speaks, so
# you get a native window onto the always-on agent running here.
#
# 1. Enable the dashboard side-process (off by default). Set to 1:
HERMES_DASHBOARD=
#
# 2. Bind host/port. Defaults: host 0.0.0.0, port = Railway's $PORT (so the
#    generated *.up.railway.app domain routes to it). Override only if needed:
HERMES_DASHBOARD_HOST=
HERMES_DASHBOARD_PORT=
#
# 3. Authentication. A non-loopback bind REQUIRES a gate — the dashboard
#    exposes your API keys. RECOMMENDED: Nous Portal OAuth ("Sign in with
#    Nous Research" from the Desktop app). Register once to get an agent:{id}
#    client id, then set it here:
#      • CLI:    hermes dashboard register
#      • Portal: https://portal.nousresearch.com/local-dashboards
HERMES_DASHBOARD_OAUTH_CLIENT_ID=
#    Portal URL override (blank → https://portal.nousresearch.com):
HERMES_DASHBOARD_PORTAL_URL=
#    Public URL the OAuth redirect_uri is built from. Auto-derived from
#    RAILWAY_PUBLIC_DOMAIN when blank; set explicitly only behind a custom
#    domain or extra proxy (e.g. https://agent.example.com):
HERMES_DASHBOARD_PUBLIC_URL=
#
#    ALTERNATIVE — username/password gate (keep behind a VPN; not ideal on a
#    public URL). Set a stable _SECRET so sessions survive restarts. Compute a
#    hash with: python -c "from plugins.dashboard_auth.basic import hash_password; print(hash_password('PW'))"
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD_HASH=
HERMES_DASHBOARD_BASIC_AUTH_SECRET=
#
#    ESCAPE HATCH (discouraged) — skip the auth gate entirely; the dashboard
#    is then protected only by the static session token. Opt in explicitly:
HERMES_DASHBOARD_INSECURE=

# --- GOOGLE WORKSPACE (OAuth + gws CLI) ---

# Base64-encoded Google OAuth credentials (required for Google Workspace access).
# Generate locally with:
#   cat ~/.hermes/google_token.json | base64 | tr -d '\n'
#   cat ~/.hermes/google_client_secret.json | base64 | tr -d '\n'
GOOGLE_TOKEN_B64=
GOOGLE_CLIENT_SECRET_B64=

# gws CLI credentials file path (auto-set by entrypoint via bridge script)
# Only set manually if you exported credentials directly with: gws auth export --unmasked
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=

# gws config directory (default: $HERMES_HOME/gws-config)
GOOGLE_WORKSPACE_CLI_CONFIG_DIR=

# --- WEB DEV PROFILE CONNECTORS (github + supabase + netlify) ---
#
# Consumed by the "web-dev" profile (docker/profiles/web-dev/config.yaml) and the
# Netlify CLI. Set these in the Railway dashboard; they are interpolated into the
# profile's mcp_servers config (${VAR}) and read by the netlify CLI at runtime.

# GitHub — Personal Access Token, sent as `Authorization: Bearer` to the hosted
# GitHub MCP server (https://api.githubcopilot.com/mcp/). Scope: repo (+ others
# as needed). Get at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# Supabase — Personal Access Token. Drives the Supabase MCP server in
# account/organization mode (NO --project-ref): access to every project the
# token can see, targeted per-call via project_id. Runs --read-only by default.
# Get at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
# (No SUPABASE_PROJECT_REF — org-wide access is intentional.)

# Netlify — auth token read by the netlify CLI (`netlify deploy`, `netlify status`).
# Get at: https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=

# Firebase — service-account key (base64 of the JSON) for the firebase CLI.
# OPTIONAL: the key already lives on the volume at
# $HERMES_HOME/firebase-service-account.json and the entrypoint exports
# GOOGLE_APPLICATION_CREDENTIALS to it. Set this only for durability across a
# volume reset. Generate with:
#   cat ~/.hermes/firebase-service-account.json | base64 | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_B64=
